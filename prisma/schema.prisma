generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String        @default("")
  name         String
  displayName  String?
  statusText   String?
  avatar       String?
  role         String        @default("user")
  googleId     String?       @unique
  totalPoints  Int           @default(100)
  streak       Int           @default(0)
  createdAt    DateTime      @default(now())
  activities        Activity[]
  adminOf           Group[]           @relation("GroupAdmin")
  memberships       GroupMember[]
  predictions       Prediction[]
  badges            UserBadge[]
  comments          Comment[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  groupChats        GroupChat[]
  groupMatchConfigs GroupMatchConfig[] @relation("ConfigUpdater")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id         String        @id @default(cuid())
  name       String
  visibility String        @default("private")
  inviteCode String        @unique
  adminId    String
  createdAt  DateTime      @default(now())
  activities   Activity[]
  admin        User          @relation("GroupAdmin", fields: [adminId], references: [id])
  members      GroupMember[]
  chats        GroupChat[]
  predictions  Prediction[]
  matchConfigs GroupMatchConfig[]
  seasons      GroupSeason[]
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("member")  // "owner" | "admin" | "member"
  points   Int      @default(0)
  wins     Int      @default(0)
  losses   Int      @default(0)
  skipped  Int      @default(0)
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

// Cấu hình kèo riêng của từng hội cho từng trận
model GroupMatchConfig {
  id              String   @id @default(cuid())
  groupId         String
  matchId         String
  ahLine          Float?
  ouLine          Float?
  allowedBetTypes String   @default("[\"ah\",\"ou\",\"exact\"]") // JSON array
  pointsMultiplier Int     @default(1)   // 1x, 2x, 3x — trận đinh nhân hệ số
  lockMinutes     Int      @default(0)   // khóa kèo trước X phút (0 = dùng mặc định hệ thống)
  blindMode       Boolean  @default(false) // ẩn pick của người khác trước kickoff
  updatedAt       DateTime @updatedAt
  updatedBy       String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  updater         User     @relation("ConfigUpdater", fields: [updatedBy], references: [id])

  @@unique([groupId, matchId])
}

// Mùa giải — snapshot standings khi reset
model GroupSeason {
  id        String    @id @default(cuid())
  groupId   String
  name      String
  snapshot  String    @default("[]") // JSON: [{userId, name, avatar, points, wins, losses, skipped}]
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Match {
  id          String       @id @default(cuid())
  homeTeam    String
  awayTeam    String
  homeFlag    String
  awayFlag    String
  homeColor   String?
  awayColor   String?
  kickoffAt   DateTime
  stage       String
  venue       String?
  status      String       @default("scheduled")
  scoreHome   Int?
  scoreAway   Int?
  minute      Int?
  ahLine      Float?
  ouLine      Float?
  weatherIcon String?
  weatherTemp Int?
  weatherCond String?
  h2hHome     Int?
  h2hDraw     Int?
  h2hAway     Int?
  h2hRecent   String?
  externalId    String?
  predictions   Prediction[]
  comments      Comment[]
  notifications Notification[]
  groupConfigs  GroupMatchConfig[]
}

model Prediction {
  id         String   @id @default(cuid())
  userId     String
  matchId    String
  groupId    String
  betType    String
  side       String?
  homeScore  Int?
  awayScore  Int?
  confidence Int      @default(3)
  result     String?
  points     Int      @default(0)
  createdAt  DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, groupId])
}

model Badge {
  code        String      @id
  name        String
  emoji       String
  description String
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeCode String
  earnedAt  DateTime @default(now())
  badge     Badge    @relation(fields: [badgeCode], references: [code], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, badgeCode])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  groupId   String?
  type      String
  action    String
  target    String
  meta      String?
  createdAt DateTime @default(now())
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  text      String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "kickoff_soon" | "goal" | "result" | "streak" | "overtaken" | "badge" | "comment"
  title     String
  body      String
  matchId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model GroupChat {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
